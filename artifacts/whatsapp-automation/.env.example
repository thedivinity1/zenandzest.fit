# WhatsApp Business API Configuration
# Required for production deployment

# WhatsApp Business API
WHATSAPP_API_KEY=your_whatsapp_api_key_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_APP_SECRET=your_app_secret

# Business Solution Provider (BSP) Configuration
# Options: twilio, messagebird, infobip, delightchat, quickreply
BSP_PROVIDER=twilio
BSP_ACCOUNT_SID=your_account_sid
BSP_AUTH_TOKEN=your_auth_token
BSP_WHATSAPP_NUMBER=+919876543210

# Server Configuration
PORT=3001
NODE_ENV=production
ALLOWED_ORIGINS=https://zenandzest.com,https://www.zenandzest.com

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/zenandzest_whatsapp

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# AI Service (for AI responses)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info
